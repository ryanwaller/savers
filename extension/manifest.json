{
  "manifest_version": 3,
  "name": "Savers",
  "version": "1.0",
  "description": "Save the current tab to Savers.",
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Save to Savers"
  },
  "permissions": ["activeTab", "contextMenus", "storage", "tabs"],
  "host_permissions": [
    "http://localhost:3000/*",
    "https://*.railway.app/*",
    "https://*.up.railway.app/*"
  ]
}
